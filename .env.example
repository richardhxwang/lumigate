# AI Provider API Keys (at least one required)
DEEPSEEK_API_KEY=sk-xxx
OPENAI_API_KEY=sk-xxx
# ANTHROPIC_API_KEY=sk-ant-xxx
# GEMINI_API_KEY=AIzaSyxxx
# KIMI_API_KEY=sk-xxx
# DOUBAO_API_KEY=xxx
# QWEN_API_KEY=sk-xxx
# MINIMAX_API_KEY=xxx

# Server
PORT=9471
GATEWAY_PORT=9471
ADMIN_SECRET=change-me-to-a-strong-password

# Deploy mode: lite | enterprise | custom
# lite = usage, chat
# enterprise = all modules
# custom = specify MODULES below
DEPLOY_MODE=lite
# MODULES=usage,budget,multikey,users,audit,metrics,backup,smart,chat

# LumiChat / PocketBase integration (enabled by default in docker-compose)
# Keep this as internal service URL unless using an external PB.
PB_URL=http://pocketbase:8090
# Optional: set for admin-level PB operations from LumiGate (tiers/subscriptions/migrations)
# PB_ADMIN_EMAIL=admin@example.com
# PB_ADMIN_PASSWORD=change-me

# Cloudflare Tunnel (optional, for public access)
# CF_TUNNEL_TOKEN_LUMIGATE=xxx
