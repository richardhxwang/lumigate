# LumiGate NAS Deployment — Environment Variables
# Copy to .env and fill in actual values

# ── Cloudflare Tunnel ──
CF_TUNNEL_TOKEN_LUMIGATE=your_cloudflare_tunnel_token_here

# ── Admin ──
ADMIN_SECRET=your_admin_secret_here

# ── Gateway ──
GATEWAY_PORT=9471
COLLECTOR_VNC_PORT=7900

# ── Ollama (Mac Mini over LAN, until Jetson arrives) ──
OLLAMA_URL=http://192.168.1.x:11434

# ── MCP Gateway ──
MCP_GATEWAY_URL=http://mcpjungle:18790

# ── PocketBase ──
PB_URL=http://host.docker.internal:8090
PB_ADMIN_EMAIL=your_pb_admin_email
PB_ADMIN_PASSWORD=your_pb_admin_password

# ── AI Provider Keys ──
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
DOUBAO_API_KEY=
QWEN_API_KEY=
MINIMAX_API_KEY=

# ── Whisper ──
WHISPER_URL=http://whisper:8080

# ── Deploy Mode (lite / enterprise / custom) ──
DEPLOY_MODE=enterprise

# ── Optional: Custom modules (when DEPLOY_MODE=custom) ──
# MODULES=usage,budget,multikey,users,audit,metrics,backup,smart,chat
