# LumiGate Mac Mini Deployment — Environment Variables
# Copy to .env and fill in actual values

# ── Ollama ──
# Binds to 0.0.0.0 so NAS can reach it over LAN
OLLAMA_HOST=0.0.0.0
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# ── Whisper (temporary, until Jetson) ──
# ASR_MODEL options: tiny, base, small, medium, large-v3
ASR_MODEL=base

# ── Mac Mini LAN IP (for NAS to connect) ──
# Update this to match your Mac Mini's actual LAN IP
# NAS docker-compose references this as OLLAMA_URL
MAC_MINI_IP=192.168.1.x
