# ============================================================
# LumiTrade — Environment Variables
# Copy to .env and fill in your values.
# ============================================================

# ── Remote Service URLs ──────────────────────────────────────
# When running standalone on NAS, point these to your LumiGate
# host (Mac Mini or wherever LumiGate runs).
# Use Docker service names only if on the same compose network.

LUMIGATE_URL=http://192.168.1.100:9471
PB_URL=http://192.168.1.100:8090
# QDRANT_URL=http://192.168.1.100:6333

# ── LumiGate Auth ────────────────────────────────────────────
# Project key for trade-engine to call LumiGate AI endpoints
LUMIGATE_PROJECT_KEY=

# ── PocketBase Admin ─────────────────────────────────────────
# Used to auto-create collections on first boot
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=

# ── Finnhub ──────────────────────────────────────────────────
# Free tier: 60 calls/min. Used for news sentiment + quotes.
FINNHUB_API_KEY=

# ── OKX (via Freqtrade) ─────────────────────────────────────
# Set these in freqtrade/config.json → exchange.key/secret/password
# or pass via env if using freqtrade env var support.
# OKX_API_KEY=
# OKX_API_SECRET=
# OKX_PASSPHRASE=

# ── Freqtrade API ────────────────────────────────────────────
# Credentials for trade-engine to call freqtrade REST API.
# Overrides config.json via FREQTRADE__API_SERVER__* env vars.
FREQTRADE_USERNAME=lumitrade
FREQTRADE_API_PASSWORD=
FREQTRADE_JWT_SECRET=
FREQTRADE_WS_TOKEN=

# ── Telegram Notifications ───────────────────────────────────
# Bot token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── IBKR (Interactive Brokers) ─────────────────────────────
IBKR_USERNAME=
IBKR_PASSWORD=
IBKR_TRADING_MODE=paper
IBKR_READ_ONLY=yes
IBKR_VNC_PASSWORD=lumitrade
